{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "gts://gts.x.chat_engine.common.session_type.v1",
  "title": "SessionType",
  "description": "Session type configuration defining the backend and capabilities",
  "type": "object",
  "properties": {
    "session_type_id": {
      "$ref": "./GtsSessionTypeId.json",
      "description": "Unique session type identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable session type name"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of the session type"
    },
    "webhook_url": {
      "type": "string",
      "format": "uri",
      "pattern": "^https?://",
      "description": "Webhook endpoint for this session type"
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "./Capability.json" },
      "description": "Capabilities provided by this session type"
    },
    "timeout_seconds": {
      "type": "integer",
      "minimum": 1,
      "maximum": 300,
      "description": "Request timeout in seconds"
    },
    "retention_policy": {
      "oneOf": [
        { "$ref": "./RetentionPolicy.json" },
        { "type": "null" }
      ],
      "description": "Data retention and lifecycle policy for sessions of this type"
    }
  },
  "required": ["session_type_id", "name", "webhook_url", "capabilities"],
  "additionalProperties": false
}
